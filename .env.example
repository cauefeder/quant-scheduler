# Quant Poly Alpha — Credentials Template
# =========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values
# 3. The .env file is gitignored — never commit it

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot
# 2. Copy the token here
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# 3. Add the bot to your group, send a message, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Find "chat":{"id": ...} and paste the number here (negative = group)
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ── Gemini AI (free — used by Poly2 and ModelTelegra) ─────────────────────────
# 1. Go to https://aistudio.google.com
# 2. Sign in → Get API key → Create API key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# ── PolyTraders config ────────────────────────────────────────────────────────
POLYTRADERS_BANKROLL=100
POLYTRADERS_TOP_N=25
POLYTRADERS_TIME_PERIOD=WEEK
