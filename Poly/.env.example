# Poly — Credentials Template
# ==============================
# The Poly scraper sends its output via the scheduler's Telegram integration.
# No direct Telegram config needed here — all comes from the root .env.
# This file is a placeholder in case you run it standalone.

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
