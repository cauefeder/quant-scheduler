# Polymarket Kelly Bot - Configuration
# Copy this file to .env and fill in your keys

# Telegram Bot
# 1. Open Telegram, search @BotFather, send /newbot
# 2. Save the token here
TELEGRAM_BOT_TOKEN=8238889935:AAFiR1llU7O2_6FpAq5e9h5nqeH_wg1D3tY

# 3. Create a group, add your bot, send a message
# 4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Find "chat":{"id":-XXXXXXXXX} and paste that number here
TELEGRAM_CHAT_ID=-5018202813

# Gemini API (FREE - no credit card needed)
# 1. Go to https://aistudio.google.com
# 2. Sign in with Google
# 3. Click Get API key > Create API key
# 4. Paste it here
GEMINI_API_KEY=AIzaSyAsVdsVO-gj6fqB-MCAWS7pWy-Wp1oYRUI

# Model choice
# gemini-2.5-flash  (recommended, fast, free)
# gemini-2.5-pro    (better reasoning, free but lower limits)
