# PolyTraders — Credentials Template
# =====================================
# Copy to .env and fill in real values (root .env is also supported)

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Bankroll in USDC to size Kelly bets against
POLYTRADERS_BANKROLL=100

# How many top traders to scan (max 50)
POLYTRADERS_TOP_N=25

# Leaderboard time period: DAY | WEEK | MONTH | ALL
POLYTRADERS_TIME_PERIOD=WEEK
